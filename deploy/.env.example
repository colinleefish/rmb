# Production runtime for deploy/docker-compose.full.yml (or host-Postgres compose).
# Copy to deploy/.env on the server. Never commit deploy/.env.

# -----------------------------------------------------------------------------
# Install / TLS
# -----------------------------------------------------------------------------

# Public hostname for Caddy automatic HTTPS (must resolve to this server).
RMB_DOMAIN=memory.example.com

# PostgreSQL password (used by the postgres container and RMB_DB_URL).
POSTGRES_PASSWORD=change_me

# Optional: skip local build and use a pre-built image instead.
# RMB_IMAGE=ghcr.io/your-org/rmb:latest
# GIT_COMMIT=unknown

# -----------------------------------------------------------------------------
# HTTP basic auth (required — rmb binds :8080 inside the stack)
# -----------------------------------------------------------------------------

USERNAME=rmb
PASSWORD=change_me

# -----------------------------------------------------------------------------
# Chat LLM (T1–T3 workers)
# -----------------------------------------------------------------------------

RMB_LLM_PROVIDER=openai
RMB_LLM_API_BASE=https://api.openai.com/v1
RMB_LLM_API_KEY=replace_me
RMB_LLM_MODEL=gpt-4o-mini
RMB_LLM_MAX_RETRIES=3
RMB_LLM_TIMEOUT=180s
RMB_LLM_THINKING_STYLE=
RMB_LLM_THINKING=disabled

# -----------------------------------------------------------------------------
# Embedding API (search + embed worker)
# -----------------------------------------------------------------------------

RMB_EMBED_ENABLED=true
RMB_EMBED_API_BASE=https://api.openai.com/v1
RMB_EMBED_API_KEY=replace_me
RMB_EMBED_MODEL=text-embedding-3-small
RMB_EMBED_DIMENSIONS=1536
RMB_EMBED_POLL_INTERVAL=30s
RMB_EMBED_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# Workers (defaults are fine for most installs)
# -----------------------------------------------------------------------------

RMB_EXTRACTION_ENABLED=true
RMB_SCENE_ENABLED=true
RMB_MEMORY_ENABLED=true
