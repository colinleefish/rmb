MEM9_DB_URL=postgres://admin@127.0.0.1:5432/mem9_db?sslmode=disable
MEM9_ADDR=:8080
# HTTP basic auth (both required if either is set). Aliases: MEM9_USERNAME / MEM9_PASSWORD
USERNAME=
PASSWORD=
MEM9_SHUTDOWN_TIMEOUT=5s
MEM9_LLM_PROVIDER=openai
MEM9_LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
MEM9_LLM_API_KEY=replace_me
MEM9_LLM_MODEL=glm-4.7
MEM9_LLM_MAX_RETRIES=3
MEM9_LLM_TIMEOUT=180s
# Reasoning toggle. Style is provider-specific:
#   thinking_type    -> {"thinking":{"type":"disabled"}}   (Xiaomi MiMo, DeepSeek)
#   enable_thinking  -> {"enable_thinking":false}          (Qwen / gateways)
#   reasoning_effort -> {"reasoning_effort":"none"}        (OpenAI-style)
# Leave MEM9_LLM_THINKING_STYLE empty to send nothing (provider default).
MEM9_LLM_THINKING_STYLE=thinking_type
MEM9_LLM_THINKING=disabled
MEM9_EXTRACTION_ENABLED=true
MEM9_EXTRACTION_POLL_INTERVAL=15s
MEM9_EXTRACTION_EVERY_N=8
MEM9_EXTRACTION_IDLE_SECONDS=600s
MEM9_EXTRACTION_WARMUP=true
MEM9_EXTRACTION_BATCH_SESSIONS=8
MEM9_EXTRACTION_MAX_TURNS_PER_BATCH=8
MEM9_EXTRACTION_MAX_CHARS_PER_BATCH=24000
MEM9_SCENE_ENABLED=true
MEM9_SCENE_POLL_INTERVAL=60s
MEM9_SCENE_DELAY_AFTER_T1=90s
MEM9_SCENE_BATCH_SESSIONS=1
MEM9_SCENE_MAX_ATOMS_PER_BATCH=60
MEM9_MEMORY_ENABLED=true
MEM9_MEMORY_POLL_INTERVAL=5m
MEM9_MEMORY_MAX_ATOMS_PER_BATCH=60
# Embed worker (separate provider/key from chat; embeds atoms/scenes/memories).
MEM9_EMBED_ENABLED=true
MEM9_EMBED_API_BASE=https://open.bigmodel.cn/api/paas/v4
MEM9_EMBED_API_KEY=replace_me
MEM9_EMBED_MODEL=embedding-3
MEM9_EMBED_DIMENSIONS=1024
MEM9_EMBED_POLL_INTERVAL=30s
MEM9_EMBED_BATCH_SIZE=32
