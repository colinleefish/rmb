MYPAST_DB_URL=postgres://admin@127.0.0.1:5432/mypast_dev?sslmode=disable
MYPAST_ADDR=:8080
# HTTP basic auth (both required if either is set). Aliases: MYPAST_USERNAME / MYPAST_PASSWORD
USERNAME=
PASSWORD=
MYPAST_SHUTDOWN_TIMEOUT=5s
MYPAST_LLM_PROVIDER=openai
MYPAST_LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
MYPAST_LLM_API_KEY=replace_me
MYPAST_LLM_MODEL=glm-4.7
MYPAST_LLM_MAX_RETRIES=3
MYPAST_LLM_TIMEOUT=180s
# Reasoning toggle. Style is provider-specific:
#   thinking_type    -> {"thinking":{"type":"disabled"}}   (Xiaomi MiMo, DeepSeek)
#   enable_thinking  -> {"enable_thinking":false}          (Qwen / gateways)
#   reasoning_effort -> {"reasoning_effort":"none"}        (OpenAI-style)
# Leave MYPAST_LLM_THINKING_STYLE empty to send nothing (provider default).
MYPAST_LLM_THINKING_STYLE=thinking_type
MYPAST_LLM_THINKING=disabled
MYPAST_EXTRACTION_ENABLED=true
MYPAST_EXTRACTION_POLL_INTERVAL=15s
MYPAST_EXTRACTION_EVERY_N=8
MYPAST_EXTRACTION_IDLE_SECONDS=600s
MYPAST_EXTRACTION_WARMUP=true
MYPAST_EXTRACTION_BATCH_SESSIONS=8
MYPAST_EXTRACTION_MAX_TURNS_PER_BATCH=8
MYPAST_EXTRACTION_MAX_CHARS_PER_BATCH=24000
MYPAST_SCENE_ENABLED=true
MYPAST_SCENE_POLL_INTERVAL=60s
MYPAST_SCENE_DELAY_AFTER_T1=90s
MYPAST_SCENE_BATCH_SESSIONS=1
MYPAST_SCENE_MAX_ATOMS_PER_BATCH=60
MYPAST_MEMORY_ENABLED=true
MYPAST_MEMORY_POLL_INTERVAL=5m
MYPAST_MEMORY_MAX_ATOMS_PER_BATCH=60
# Embed worker (separate provider/key from chat; embeds atoms/scenes/memories).
MYPAST_EMBED_ENABLED=true
MYPAST_EMBED_API_BASE=https://open.bigmodel.cn/api/paas/v4
MYPAST_EMBED_API_KEY=replace_me
MYPAST_EMBED_MODEL=embedding-3
MYPAST_EMBED_DIMENSIONS=1024
MYPAST_EMBED_POLL_INTERVAL=30s
MYPAST_EMBED_BATCH_SIZE=32
