RMB_DB_URL=postgres://admin@127.0.0.1:5432/rmb_db?sslmode=disable
RMB_ADDR=127.0.0.1:8080
# Public bind (e.g. :8080) requires USERNAME and PASSWORD below.
# RMB_MAX_UPLOAD_BYTES=33554432
# HTTP basic auth (both required if either is set): RMB_USERNAME / RMB_PASSWORD
USERNAME=
PASSWORD=
RMB_SHUTDOWN_TIMEOUT=5s
RMB_LLM_PROVIDER=openai
RMB_LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
RMB_LLM_API_KEY=replace_me
RMB_LLM_MODEL=glm-4.7
RMB_LLM_MAX_RETRIES=3
RMB_LLM_TIMEOUT=180s
# Reasoning toggle. Style is provider-specific:
#   thinking_type    -> {"thinking":{"type":"disabled"}}   (Xiaomi MiMo, DeepSeek)
#   enable_thinking  -> {"enable_thinking":false}          (Qwen / gateways)
#   reasoning_effort -> {"reasoning_effort":"none"}        (OpenAI-style)
# Leave RMB_LLM_THINKING_STYLE empty to send nothing (provider default).
RMB_LLM_THINKING_STYLE=thinking_type
RMB_LLM_THINKING=disabled
RMB_EXTRACTION_ENABLED=true
RMB_EXTRACTION_POLL_INTERVAL=15s
RMB_EXTRACTION_EVERY_N=8
RMB_EXTRACTION_IDLE_SECONDS=600s
RMB_EXTRACTION_WARMUP=true
RMB_EXTRACTION_BATCH_SESSIONS=8
RMB_EXTRACTION_MAX_TURNS_PER_BATCH=8
RMB_EXTRACTION_MAX_CHARS_PER_BATCH=24000
RMB_SCENE_ENABLED=true
RMB_SCENE_POLL_INTERVAL=60s
RMB_SCENE_DELAY_AFTER_T1=90s
RMB_SCENE_BATCH_SESSIONS=1
RMB_SCENE_MAX_ATOMS_PER_BATCH=60
RMB_MEMORY_ENABLED=true
RMB_MEMORY_POLL_INTERVAL=5m
RMB_MEMORY_MAX_ATOMS_PER_BATCH=60
# Embed worker (separate provider/key from chat; embeds atoms/scenes/memories).
RMB_EMBED_ENABLED=true
RMB_EMBED_API_BASE=https://open.bigmodel.cn/api/paas/v4
RMB_EMBED_API_KEY=replace_me
RMB_EMBED_MODEL=embedding-3
RMB_EMBED_DIMENSIONS=1024
RMB_EMBED_POLL_INTERVAL=30s
RMB_EMBED_BATCH_SIZE=32
