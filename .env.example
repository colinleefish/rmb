# rmb server configuration (rmb serve)
# Copy to .env and edit. Loaded from the working directory; env vars override.
# Client recall/hooks use ~/.rmb.conf or ~/.rmb/config.yaml (RMB_URL, auth).

# =============================================================================
# Database
# =============================================================================

# PostgreSQL connection string (pgvector required).
# Docker Compose (in-container): postgres://rmb:rmb@postgres:5432/rmb_db?sslmode=disable
# Docker Compose (host → compose DB): postgres://rmb:rmb@127.0.0.1:5433/rmb_db?sslmode=disable
RMB_DB_URL=postgres://admin@127.0.0.1:5432/rmb_db?sslmode=disable

# =============================================================================
# HTTP server
# =============================================================================

# Listen address. Use 127.0.0.1 for local-only; :8080 or 0.0.0.0 requires auth below.
RMB_ADDR=127.0.0.1:8080

# Graceful shutdown wait before force-close.
RMB_SHUTDOWN_TIMEOUT=5s

# Max request body size for uploads (bytes). Default 32 MiB if unset.
# RMB_MAX_UPLOAD_BYTES=33554432

# =============================================================================
# HTTP basic auth
# =============================================================================

# Required when binding off localhost (both must be set if either is set).
# Aliases: RMB_USERNAME / RMB_PASSWORD
USERNAME=
PASSWORD=

# =============================================================================
# Chat LLM (T1 extraction, T2 scene, T3 memory workers)
# =============================================================================

# Provider tag (only "openai" compatible endpoints supported today).
RMB_LLM_PROVIDER=openai

# OpenAI-compatible chat-completions base URL.
RMB_LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4

# API key for chat workers (required for distillation).
RMB_LLM_API_KEY=replace_me

# Model name passed to /chat/completions.
RMB_LLM_MODEL=glm-4.7

# Retries per LLM request on transient errors.
RMB_LLM_MAX_RETRIES=3

# Per-request HTTP timeout for chat calls.
RMB_LLM_TIMEOUT=180s

# Reasoning / thinking toggle sent to the provider (provider-specific JSON).
# Style: thinking_type (MiMo, DeepSeek) | enable_thinking (Qwen) | reasoning_effort (OpenAI)
# Leave RMB_LLM_THINKING_STYLE empty to omit the field (provider default).
RMB_LLM_THINKING_STYLE=thinking_type

# enabled | disabled — whether reasoning mode is on.
RMB_LLM_THINKING=disabled

# =============================================================================
# T1 extraction worker (turns → atoms)
# =============================================================================

# Master switch for atom extraction.
RMB_EXTRACTION_ENABLED=true

# How often the worker polls for new work.
RMB_EXTRACTION_POLL_INTERVAL=15s

# Extract after every N new turns in a session.
RMB_EXTRACTION_EVERY_N=8

# Also extract when a session has been idle this long.
RMB_EXTRACTION_IDLE_SECONDS=600s

# Run extraction on server startup for sessions with pending turns.
RMB_EXTRACTION_WARMUP=true

# Max sessions claimed per poll cycle.
RMB_EXTRACTION_BATCH_SESSIONS=8

# Max turns batched into one LLM extraction call.
RMB_EXTRACTION_MAX_TURNS_PER_BATCH=8

# Max characters batched into one LLM extraction call.
RMB_EXTRACTION_MAX_CHARS_PER_BATCH=24000

# =============================================================================
# T2 scene worker (atoms → scenes, session abstract)
# =============================================================================

# Master switch for scene synthesis.
RMB_SCENE_ENABLED=true

# How often the worker polls for sessions ready for T2.
RMB_SCENE_POLL_INTERVAL=60s

# Wait after T1 finishes before starting T2 for a session.
RMB_SCENE_DELAY_AFTER_T1=90s

# Max sessions processed per poll cycle.
RMB_SCENE_BATCH_SESSIONS=1

# Max atoms fed into one scene LLM call.
RMB_SCENE_MAX_ATOMS_PER_BATCH=60

# =============================================================================
# T3 memory worker (atoms → cross-session memories)
# =============================================================================

# Master switch for long-term memory rollup.
RMB_MEMORY_ENABLED=true

# How often the worker polls for memory candidates.
RMB_MEMORY_POLL_INTERVAL=5m

# Max atoms processed per memory batch.
RMB_MEMORY_MAX_ATOMS_PER_BATCH=60

# =============================================================================
# Embedding API & worker (semantic search + vector index)
# =============================================================================

# Master switch for the background embed worker.
RMB_EMBED_ENABLED=true

# OpenAI-compatible /embeddings base URL (can differ from chat API).
RMB_EMBED_API_BASE=https://open.bigmodel.cn/api/paas/v4

# API key for embeddings (required for rmb search and recall endpoints).
RMB_EMBED_API_KEY=replace_me

# Embedding model name.
RMB_EMBED_MODEL=embedding-3

# Vector dimensions stored in pgvector (must match the model).
RMB_EMBED_DIMENSIONS=1024

# How often the embed worker polls for rows missing embeddings.
RMB_EMBED_POLL_INTERVAL=30s

# Rows embedded per API call.
RMB_EMBED_BATCH_SIZE=32

# Per-request HTTP timeout for embedding calls.
# RMB_EMBED_TIMEOUT=60s
