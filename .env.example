MYPAST_DB_URL=postgres://admin@127.0.0.1:5432/mypast_dev?sslmode=disable
MYPAST_ADDR=:8080
MYPAST_SHUTDOWN_TIMEOUT=5s
MYPAST_VLM_PROVIDER=openai
MYPAST_VLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
MYPAST_VLM_API_KEY=replace_me
MYPAST_VLM_MODEL=glm-4.7
MYPAST_VLM_MAX_RETRIES=1
MYPAST_VLM_TIMEOUT=90s
MYPAST_SUMMARIZER_ENABLED=true
MYPAST_SUMMARIZER_POLL_INTERVAL=15s
MYPAST_SUMMARIZER_BATCH_SIZE=8
MYPAST_SUMMARIZER_STALE_AFTER=3m
MYPAST_SUMMARIZER_MAX_TURNS_PER_MERGE=4
MYPAST_SUMMARIZER_MAX_CHARS_PER_MERGE=16000
